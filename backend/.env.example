DATABASE_URL="postgresql://user:password@localhost:5432/delivery_tracker"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Admin seed credentials (REQUIRED before running node prisma/seed.js)
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="change-this-to-a-strong-password"

# Optional: demo accounts for dev/staging only — leave blank in production
DEMO_CUSTOMER_EMAIL=
DEMO_CUSTOMER_PASSWORD=
DEMO_AGENT_EMAIL=
DEMO_AGENT_PASSWORD=

# Email (SMTP) - leave blank to use Ethereal test account in dev
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="noreply@delivery.com"

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
